# Geometra Environment Configuration

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=geometra

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# File Storage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# Agent Configuration
MAX_FILE_SIZE_MB=50
SUPPORTED_2D_FORMATS=pdf,png,jpeg,tiff,dxf,dwg
SUPPORTED_3D_FORMATS=step,stp,iges,stl,obj
